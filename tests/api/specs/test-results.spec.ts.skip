/**
 * Test Results API Test Suite
 * Endpoints: GET /test_results, GET /test_results/{id}
 * Base URL: https://app.testsigma.com/api/v1/
 */

import { test, expect } from '@playwright/test';
import { TestResultsClient } from '../clients/test-results.client';

test.describe('@api @regression Test Results API', () => {
  let client: TestResultsClient;

  test.beforeEach(async ({ request }) => {
    client = new TestResultsClient(request);
  });

  test('should retrieve list of test results with valid status and schema', async () => {
    const result = await client.list();

    expect(result.status).toBe(200);
    expect(result.data).toBeDefined();
    expect(Array.isArray(result.data)).toBe(true);

    if (result.data.length > 0) {
      const testResult = result.data[0];
      expect(testResult).toHaveProperty('id');
      expect(testResult).toHaveProperty('name');
    }
  });

  test('should return 401 when Authorization header is missing', async ({
    request,
  }) => {
    const response = await request.get(
      'https://app.testsigma.com/api/v1/test_results'
    );
    expect(response.status()).toBe(401);
  });

  test('should return 404 when getting non-existent test result', async () => {
    const result = await client.get('999999999');
    expect(result.status).toBe(404);
  });
});
